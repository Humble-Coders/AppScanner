rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Users can read/write their own user document (FCM token storage)
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // Lookup by phone → userId + fcmToken (written only by the user who owns that phone)
    match /phoneDirectory/{phone} {
      allow read: if request.auth != null;
      allow create, update: if request.auth != null
        && request.resource.data.userId == request.auth.uid;
      allow delete: if request.auth != null && resource.data.userId == request.auth.uid;
    }

    // Guardian tokens: guardian writes own row; protected user can add by copying token from phoneDirectory
    match /guardians/{protectedUserId}/tokens/{guardianUid} {
      allow write: if request.auth != null && (
        request.auth.uid == guardianUid || request.auth.uid == protectedUserId
      );
      allow read: if request.auth != null && request.auth.uid == protectedUserId;
    }
  }
}
